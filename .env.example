# .env.example – Template für Umgebungsvariablen
# Kopiere diese Datei zu .env und fülle die Werte aus
# WICHTIG: .env niemals in Git committen!

# Datenbank – gleiche Postgres-Instanz wie der Trading Bot, eigene Tabellen (Präfix "pos_")
DATABASE_URL=postgresql://trading_bot_user:password@localhost/trading_bot

# Anthropic Claude API (kann mit dem Trading Bot geteilt werden)
ANTHROPIC_API_KEY=sk-ant-...

# Basis-URL des Dashboards (für Bestätigungs-Links in E-Mails)
BASE_URL=https://portfolio.straesschen.de

# Alerts
ALERT_EMAIL=deine@email.de

# SMTP für E-Mail-Versand (optional – ohne diese Werte wird nur geloggt)
# Gleiche Werte wie beim Trading Bot verwendbar.
SMTP_HOST=mail.gmx.net
SMTP_PORT=465
SMTP_FALLBACK_PORT=2525
SMTP_USER=absender@gmx.de
SMTP_PASSWORD=passwort

# Rebalancing-Schwellwerte (Dezimalanteil, z.B. 0.10 = 10%)
REBALANCING_THRESHOLD_ALERT=0.10
REBALANCING_THRESHOLD_SPARRATE=0.05
REBALANCING_THRESHOLD_SELL=0.15

# Steuer-Defaults (Deutschland)
ABGELTUNGSSTEUER=0.25
SOLI=0.055
KIRCHENSTEUER_SATZ=0.09
FREISTELLUNGSAUFTRAG_DEFAULT=1000.0
